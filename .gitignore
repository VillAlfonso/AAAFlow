# ============ AAAFlow .gitignore ============

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# --- Virtual environments ---
.venv/
venv/
env/
trainers/musubi-tuner/.venv/

# --- Model weights (never commit large weights) ---
models/
trainers/weights/
*.safetensors
*.gguf
*.ckpt
*.pt
*.pth

# --- ComfyUI portable (huge, user-provided) ---
ComfyUI_windows_portable/

# --- Vendored LTX-2 source (huge, nested git repo; not our source) ---
ltx2.3pro/

# --- External trainer clone (cloned by setup, not our source) ---
trainers/musubi-tuner/

# --- Vendored ACE-Step source (music engine; huge, nested git repo; not our source) ---
ACE-Step-1.5/

# --- Stray model dirs/files if they ever land at the repo root ---
# (ComfyUI model dirs belong under ComfyUI_windows_portable/; these at root are
#  accidental, e.g. a mis-redirected download script)
/checkpoints
/loras
/text_encoders
/diffusion_models
/vae

# --- Generated data / runtime state ---
data/backups/
data/outputs/
data/refs/
# Per-channel folders: track the small identity (channel.json, ui/, brand
# graphs), NEVER the heavy media (projects, rendered brand PNGs/mp4s).
# project.json content is mirrored to data/backups/ on every save.
data/channels/*/projects/
data/channels/*/brand/*
!data/channels/*/brand/graphs/
data/ambiance/
data/training_runs/
# cartoon RAG reference pack (seeded/uploaded), and runtime logs
data/style_refs/
data/*.json
data/*.log
data/projects/*/audio/
data/projects/*/images/
data/projects/*/video/
data/projects/*/*.backup.*.json

# --- Local test artifacts (smoke tests write these to the repo root) ---
cartoon_rag_test.*
*_ltxtest.mp4

# --- LoRA training: keep the READMEs + folder structure, ignore the heavy bits ---
training/**/dataset/
training/**/cache/
training/**/output/
training/**/dataset.toml
training/**/*.jpg
training/**/*.jpeg
training/**/*.png
training/**/*.webp
training/**/*.txt

# --- Legacy / vendored ---
QwenTTS/
third_party/Qwen3-TTS/.git/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.log
*.tmp

# --- Per-channel YouTube OAuth credentials (NEVER commit) ---
data/secrets/

# --- Editor / tooling ---
.vscode/
.idea/

# --- Node / JS ---
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Local env files ---
.env
.env.local
.env.*.local

# --- Python / test caches ---
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
pip-wheel-metadata/

# --- Databases / caches ---
*.sqlite3
*.db
*.sqlite
.cache/

# --- Source maps / build artifacts ---
*.map
