# ============ AAAFlow .gitignore ============
#
# RULE OF THUMB (after the 2026-07-09 data loss): commit the things that
# DEFINE the studio (code, docs, channel identities, dictionaries), ignore
# the things the machine can REGENERATE (weights, renders, caches) and the
# things that must never leave this machine (secrets).
#
# Anything under data/ that is ignored here is NOT protected by git, so the
# app also keeps its own local safety nets:
#   data/channels.backup.json     every channel record, rewritten on save
#   data/backups/projects/*.json  every project.json, mirrored on save
# Never run `git clean` in this repo without `-n` first.

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# --- Virtual environments ---
.venv/
venv/
env/
trainers/musubi-tuner/.venv/

# --- Model weights (never commit large weights) ---
models/
trainers/weights/
*.safetensors
*.gguf
*.ckpt
*.pt
*.pth

# --- ComfyUI portable (huge, user-provided) ---
ComfyUI_windows_portable/

# --- Vendored LTX-2 source (huge, nested git repo; not our source) ---
LTX-Video/
ACE-Step-1.5/

# --- Standalone AAADataGatherer (own nested repo; superseded by
# app/gatherer.py + the Data Gatherer page, kept only as reference) ---
AAADataGatherer/

# ============================================================
# data/ — the important half of this file
# ============================================================

# --- SECRETS: never commit (YouTube OAuth, API keys) ---
data/secrets/
.env
.env.*

# --- KEEP (tracked): the channel identities + their editable generators ---
#   data/channels/<cid>/channel.json   the channel record
#   data/channels/<cid>/ui/            per-channel theme
#   data/channels/<cid>/brand/graphs/  the ComfyUI node graphs
data/channels/*/brand/*
!data/channels/*/brand/graphs/
!data/channels/*/brand/graphs/**

# --- KEEP (tracked): every project's STORYBOARD (small text, irreplaceable).
# The 2026-07-09 loss was survivable only because the scripts existed outside
# data/. Now git holds them. The media a project renders (audio/, images/,
# video/, thumbs) is regenerable, so it stays ignored.
data/channels/*/projects/**
!data/channels/*/projects/
!data/channels/*/projects/*/
!data/channels/*/projects/*/project.json
!data/channels/*/projects/*/source.json
!data/channels/*/projects/*/HANDOFF.md

# --- Data gatherer evidence packs: media ignored, the tiny gather.json
# record (URL + options + summary = the full re-run recipe) stays tracked ---
data/gatherer/*/*
!data/gatherer/*/gather.json

# --- Channel studies: branding images ignored, the record + the distilled
# SKILL PACKS (the whole point of a study) stay tracked ---
data/studies/*/*
!data/studies/*/study.json
!data/studies/*/skills/
!data/studies/*/skills/**

# --- Generated media / runtime state (regenerable, often multi-GB) ---
data/projects/
data/restored/
data/backups/
data/trash/
data/outputs/
data/refs/
data/ambiance/
data/music/
data/audio_library/
data/parallax_cache/
data/upscale_cache/
data/training_runs/
data/style_refs/
data/roulette/*/*.png
data/*.log
data/server*.log

# --- LoRA datasets: the training CLIPS are reference footage (never ship,
# multi-GB) and the caches/checkpoints are regenerable. The manifest + the
# dataset.toml + the CAPTIONS are the recipe, so they stay tracked: they are
# what makes a LoRA reproducible (see the /lora-train skill). ---
data/lora_datasets/*/clips/*.mp4
data/lora_datasets/*/clips_captions_v1/
data/lora_datasets/*/cache/
data/lora_datasets/*/out/
data/lora_datasets/*/*.log

# --- Loose runtime json in data/ (settings, history, library indexes) ---
# The DICTIONARIES that shape every video are tracked explicitly below.
data/*.json
!data/effects_dictionary.json
!data/effects_presets.json
!data/thumb_templates.json
!data/brandkit_slots.json
!data/sfx_library.json
!data/overlay_rules.json
!data/technique_executors.json

# --- Training scratch ---
training/**/dataset/
training/**/dataset.toml
pip-wheel-metadata/

# --- Databases / caches ---
*.sqlite
*.db
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# --- Local scratch ---
.playwright-mcp/
scratchpad/
!scratchpad/poll.py
# the storyboards recovered from the 2026-07-09 loss: keep them in git forever
!scratchpad/recovered/
!scratchpad/recovered/**

# nested repo (vendored trainer)
trainers/musubi-tuner/

# remotion overlay renderer deps
tools/remotion/node_modules/
data/server.log*
